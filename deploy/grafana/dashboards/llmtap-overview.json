{
  "title": "LLM Observability — llmtap",
  "uid": "llmtap-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["llmtap", "genai"],
  "templating": {
    "list": [
      {
        "name": "model",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(gen_ai_client_operation_duration_seconds_count, gen_ai_request_model)", "refId": "ModelQuery" },
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests / second by model",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_operation_duration_seconds_count{gen_ai_request_model=~\"$model\"}[5m]))",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "p50 / p95 / p99 latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_request_model=~\"$model\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_request_model=~\"$model\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(gen_ai_client_operation_duration_seconds_bucket{gen_ai_request_model=~\"$model\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Time to first token (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, gen_ai_request_model) (rate(gen_ai_client_time_to_first_token_seconds_bucket{gen_ai_request_model=~\"$model\"}[5m])))",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Tokens / second (input vs output)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (token_type, gen_ai_request_model) (rate(gen_ai_client_token_usage_token_sum{gen_ai_request_model=~\"$model\"}[5m]))",
          "legendFormat": "{{gen_ai_request_model}} / {{token_type}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Estimated cost ($/hour)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_cost_usd_total{gen_ai_request_model=~\"$model\"}[5m])) * 3600",
          "legendFormat": "{{gen_ai_request_model}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "In-flight requests",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(llmtap_requests_in_flight)" }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Total requests",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(llmtap_requests_total)" }
      ]
    }
  ]
}
